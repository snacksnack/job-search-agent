      "observability / reliability",
      "fintech / data products"
    ],
    "secondaryIncludeTitles": {
      "note": "Adjacent titles that should APPEAR on the board but rank BELOW the primary targetTitles. Technical Project Manager is a coordination-leaning cousin of Technical Program Manager — included, but deliberately scored lower so true Program Manager roles sort above it. Plain non-technical 'Project Manager' is NOT here and stays excluded.",
      "titles": [
        "Technical Project Manager",
